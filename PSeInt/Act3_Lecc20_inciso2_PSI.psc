// Un programa que pida una calificación de un alumno e indique si está aprobado o reprobado  
Proceso alumno_aprobado_o_reprobado
	Definir nota Como Real
	Escribir 'Ingrese la nota final del estudiante'
	Si nota>70 Entonces
		Escribir 'Alumno aprobado'
	SiNo
		Escribir 'Alumno reprobado'
	FinSi
FinProceso
